# ─── Backend API ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ─── Security (set to false in local dev, true in production) ─────────────────
NEXT_PUBLIC_RECAPTCHA_ENABLED=false
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

NEXT_PUBLIC_RATE_LIMITER_ENABLED=false

NEXT_PUBLIC_XSS_SANITIZE_ENABLED=false

# ─── reCAPTCHA server-side verification (only needed in Server Actions) ────────
RECAPTCHA_SECRET_KEY=

# ─── PWA ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Advisor Cricket"
NEXT_PUBLIC_APP_SHORT_NAME="Advisor"
